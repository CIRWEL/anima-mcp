# Anima environment — copy to ~/.anima/anima.env on Pi
# anima.env is gitignored pattern; never commit real keys
#
# Required for LLM features (VQA, self-answering, etc.):
# GROQ_API_KEY=gsk_xxx   # Get free key at groq.com
#
# Required for UNITARES governance:
# UNITARES_AUTH=unitares:your-password
#
# Required for WiFi watchdog auto-reconnect:
# WIFI_SSID=YourNetworkName
# WIFI_PASSWORD=YourPassword

GROQ_API_KEY=
UNITARES_AUTH=
WIFI_SSID=
WIFI_PASSWORD=
